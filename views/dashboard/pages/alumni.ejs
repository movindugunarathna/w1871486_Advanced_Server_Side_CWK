<% var pageTitle = 'Alumni Browser'; %>
<%- include('../partials/layout') %>

<h2 class="mb-4">Alumni Browser</h2>

<form id="alumniFilterForm" class="row g-2 mb-4">
  <div class="col-md-3">
    <select name="programme" class="form-select" id="alumniProgrammeFilter">
      <option value="">All Programmes</option>
    </select>
  </div>
  <div class="col-md-2">
    <select name="graduationYear" class="form-select" id="alumniGraduationYearFilter">
      <option value="">All Graduation Years</option>
    </select>
  </div>
  <div class="col-md-3">
    <select name="industrySector" class="form-select" id="alumniIndustrySectorFilter">
      <option value="">All Industry Sectors / Roles</option>
    </select>
  </div>
  <div class="col-md-2">
    <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
  </div>
  <div class="col-md-2">
    <button type="reset" class="btn btn-outline-secondary w-100" id="clearAlumniFilters">Clear</button>
  </div>
</form>

<button id="exportAlumniCsv" class="btn btn-outline-success mb-3">Export Alumni CSV</button>

<div id="alumniLoading" class="text-center py-4" style="display:none;">
  <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
</div>

<div id="alumniError" class="alert alert-danger" style="display:none;"></div>

<div class="table-responsive">
  <table class="table table-striped table-hover" id="alumniTable">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Degree</th>
        <th>Employer</th>
        <th>Certifications</th>
        <th>LinkedIn</th>
      </tr>
    </thead>
    <tbody id="alumniTableBody">
    </tbody>
  </table>
</div>

<nav id="alumniPagination" class="d-flex justify-content-center">
  <ul class="pagination">
  </ul>
</nav>

<%- include('../partials/footer') %>
