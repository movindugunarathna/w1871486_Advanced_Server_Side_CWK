<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password — University Analytics Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/dashboard.css">
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center mt-5">
      <div class="col-md-5">
        <div class="card shadow-sm">
          <div class="card-body p-4">
            <h3 class="card-title text-center mb-4">Analytics Dashboard</h3>
            <h5 class="text-center text-muted mb-4">Set New Password</h5>
            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <% if (success) { %>
              <div class="alert alert-success"><%= success %>
                <br><a href="/dashboard/login">Sign in now</a>
              </div>
            <% } %>
            <% if (!success) { %>
            <form method="POST" action="/dashboard/reset-password?token=<%= token %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" class="form-control" id="newPassword" name="newPassword" required minlength="8">
                <div class="form-text">Min 8 chars, 1 uppercase, 1 lowercase, 1 number, 1 special character</div>
              </div>
              <button type="submit" class="btn btn-primary w-100">Reset Password</button>
            </form>
            <% } %>
            <p class="text-center mt-3 mb-0">
              <a href="/dashboard/login">Back to Sign In</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
