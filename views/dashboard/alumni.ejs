<% var pageTitle = 'Alumni Browser'; %>
<%- include('layout') %>

<h2 class="mb-4">Alumni Browser</h2>

<form id="alumniFilterForm" class="row g-2 mb-4">
  <div class="col-md-3">
    <input name="programme" class="form-control" placeholder="Programme...">
  </div>
  <div class="col-md-2">
    <input name="graduationYear" type="number" class="form-control" placeholder="Graduation Year">
  </div>
  <div class="col-md-3">
    <input name="industrySector" class="form-control" placeholder="Industry Sector...">
  </div>
  <div class="col-md-2">
    <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
  </div>
  <div class="col-md-2">
    <button type="reset" class="btn btn-outline-secondary w-100" id="clearAlumniFilters">Clear</button>
  </div>
</form>

<div id="alumniLoading" class="text-center py-4" style="display:none;">
  <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
</div>

<div id="alumniError" class="alert alert-danger" style="display:none;"></div>

<div class="table-responsive">
  <table class="table table-striped table-hover" id="alumniTable">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Degree</th>
        <th>Employer</th>
        <th>Certifications</th>
        <th>LinkedIn</th>
      </tr>
    </thead>
    <tbody id="alumniTableBody">
    </tbody>
  </table>
</div>

<nav id="alumniPagination" class="d-flex justify-content-center">
  <ul class="pagination">
  </ul>
</nav>

<%- include('footer') %>
