# ==============================================
# Alumni Influencers API — Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# XAMPP defaults are pre-filled where applicable.

# ── Database (XAMPP MySQL defaults) ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=alumni_influencers

# ── Server ──
# If you see EADDRINUSE on 5000, pick another port (e.g. 5001) and set BASE_URL + CORS_ORIGIN to match.
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# ── Auth ──
SESSION_SECRET=change-this-to-a-random-string
JWT_SECRET=change-this-to-another-random-string

# ── Email (Nodemailer SMTP) ──
# Leave EMAIL_USER and EMAIL_PASS empty to use Ethereal (fake SMTP) in development
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@eastminster.ac.uk

# ── University ──
UNIVERSITY_DOMAIN=@eastminster.ac.uk

# ── CORS ──
CORS_ORIGIN=http://localhost:5000

# ── Part 2 — Analytics Dashboard API Key ──
# Generate: POST /api/developer/api-keys
#   Body: { "name": "Analytics Dashboard", "permissions": ["read:alumni","read:analytics"] }
ANALYTICS_API_KEY=
# Set true to serve analytics dashboard charts from analytics-dashboard-demo-data.json
# Useful for demos without relying on real DB analytics volume.
DASHBOARD_DEMO_MODE=false

# ── AR App API Key (separate scoped key) ──
# Generate: POST /api/developer/api-keys
#   Body: { "name": "AR App", "permissions": ["read:alumni_of_day"] }
AR_APP_API_KEY=
